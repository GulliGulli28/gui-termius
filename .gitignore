# Rust build output
/target
/src-tauri/target
# rdp-sidecar is its own separate Cargo workspace (see rdp-sidecar/Cargo.toml)
/rdp-sidecar/target

# Per-platform rdp-sidecar binary, built locally/in CI and copied here for
# `bundle.externalBin` — never committed, see CLAUDE.md's "Pourquoi un
# processus RDP séparé" section for the build command.
/src-tauri/binaries/

# Node
/node_modules
/dist

# Retired UIs kept on disk for reference only, not part of the build
# (see the root Cargo.toml workspace comment) — never meant to be tracked.
/app
/term

# Auto-regenerated by tauri-build at every compile from capabilities/
# plugins — committing it just creates diff noise on every build.
/src-tauri/gen/schemas

# TypeScript incremental build cache
*.tsbuildinfo

# Emitted by `tsc -b` (composite project reference) for vite.config.ts,
# regenerated on every `npm run build` — not meant to be tracked.
/vite.config.d.ts

# Windows "mark of the web" metadata that can end up literally named
# `<file>:Zone.Identifier` when copied through certain tools — invalid
# on NTFS (breaks native Windows checkouts) and never useful to track.
*:Zone.Identifier

# Editor / OS cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs and other local-only scratch files
*.log
*.local

# Screenshots/output from scripts/visual-check-*.mjs (Playwright)
/scripts/.output
