{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gui-termius",
  "identifier": "dev.guitermius.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gui-termius",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "externalBin": ["binaries/rdp-sidecar"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExQTUwMkI1OUY5RTlGNEEKUldSS241NmZ0UUtsb1lRSGNLS29ZS2NrMjJ4OTNjUlZ4NmVjY1VnMTNCeUVJK25mTWhFTjF2NzAK",
      "endpoints": [
        "https://github.com/GulliGulli28/gui-termius/releases/latest/download/latest.json"
      ]
    }
  }
}
